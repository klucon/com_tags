{
  "schema_version": "1.0",
  "name": "com_tags",
  "type": "component",
  "vendor": "klucon",
  "extension_id": "klucon/com_tags",
  "version": "0.1.2",
  "display_name": "Tagy",
  "display_name_key": "extensions.name.com_tags",
