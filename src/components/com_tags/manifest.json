    "featured": false
  },
  "min_cms_version": "0.1.0",
  "categories": [
    "content"
  ],
  "supported_locales": [
    "cs_CZ",
    "en_GB"
  ],
  "changelog": "Oprava FastAPI route anotaci pro kompatibilitu s aktualni verzi frameworku.",
  "routes": {
    "admin": {
      "enabled": true,
      "prefix": "/admin/com_tags",
      "nav_label": "extensions.name.com_tags",
      "nav_icon": "tags",
      "nav_order": 120
